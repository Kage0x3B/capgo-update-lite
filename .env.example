# Copy to `.env` and fill in. Loaded by wrangler at startup as process env.
#
# Hyperdrive local-dev override for the HYPERDRIVE binding. postgres.js reads
# the connection string from here when running `wrangler dev`. Secrets in
# `.dev.vars` are for the *Worker's* env; this one is for wrangler itself.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgres://capgo_update_lite:<password>@<host>:<port>/capgo_update_lite?sslmode=require"
