{
    "name": "capgo-update-lite",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "deploy": "vite build && wrangler deploy",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "cf-typegen": "wrangler types"
    },
    "devDependencies": {
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.57.1",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/forms": "^0.5.11",
        "@types/node": "^25.6.0",
        "@valibot/to-json-schema": "^1.6.0",
        "drizzle-kit": "^0.31.10",
        "svelte": "^5.55.4",
        "svelte-check": "^4.4.6",
        "typescript": "^5.9.0",
        "vite": "^8.0.9",
        "wrangler": "^4.84.1"
    },
    "dependencies": {
        "@skeletonlabs/skeleton": "^4.15.2",
        "@skeletonlabs/skeleton-svelte": "^4.15.2",
        "@tailwindcss/vite": "^4.2.4",
        "aws4fetch": "^1.0.20",
        "drizzle-orm": "^0.45.2",
        "jszip": "^3.10.1",
        "layercake": "^10.0.2",
        "nanoid": "^5.1.9",
        "postgres": "^3.4.9",
        "tailwindcss": "^4.2.4",
        "valibot": "^1.3.1"
    },
    "cloudflare": {
        "bindings": {
            "HYPERDRIVE": {
                "description": "Postgres database via Hyperdrive. The wizard will prompt for a connection string — any Postgres (Neon, Supabase, RDS, self-hosted) works. After deploy, apply the schema with `pnpm db:push`."
            },
            "BUNDLES": {
                "description": "R2 bucket for uploaded OTA bundles. The server issues **presigned upload URLs** via the R2 S3 API, so you'll also need to mint an R2 API token and set three secrets after first deploy: `R2_S3_ENDPOINT`, `R2_ACCESS_KEY_ID`, `R2_SECRET_ACCESS_KEY`. See the repo README for the full checklist."
            },
            "ASSETS": {
                "description": "Static assets binding for the SvelteKit client bundle. No action needed."
            }
        }
    }
}
