{
    "name": "capgo-update-lite",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc -p scripts/tsconfig.json",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "deploy": "vite build && wrangler deploy",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "publish-bundle": "tsx scripts/publish.ts",
        "cf-typegen": "wrangler types"
    },
    "devDependencies": {
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.57.1",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@tailwindcss/forms": "^0.5.11",
        "@types/node": "^25.6.0",
        "@valibot/to-json-schema": "^1.6.0",
        "drizzle-kit": "^0.31.10",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^3.5.1",
        "prettier-plugin-tailwindcss": "0.7.3",
        "svelte": "^5.55.4",
        "svelte-check": "^4.4.6",
        "tsx": "^4.21.0",
        "typescript": "^5.9.0",
        "vite": "^8.0.9",
        "wrangler": "^4.84.1"
    },
    "dependencies": {
        "@skeletonlabs/skeleton": "^4.15.2",
        "@skeletonlabs/skeleton-svelte": "^4.15.2",
        "@tailwindcss/vite": "^4.2.4",
        "aws4fetch": "^1.0.20",
        "drizzle-orm": "^0.45.2",
        "jszip": "^3.10.1",
        "layercake": "^10.0.2",
        "nanoid": "^5.1.9",
        "postgres": "^3.4.9",
        "tailwindcss": "^4.2.4",
        "valibot": "^1.3.1"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "workerd"
        ]
    }
}
