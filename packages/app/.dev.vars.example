# Copy to `.dev.vars` and fill in. Loaded by `wrangler dev` as the Worker's
# runtime env. The Deploy-to-Cloudflare wizard also reads this file to prompt
# for required secrets during the initial deploy.
#
# PRIVATE_ADMIN_TOKEN is intentionally not listed here — it's consumed via
# `$env/static/private` at build time; set it in `.env` instead.

# R2 S3-compatible credentials. Create an R2 API token in the Cloudflare
# dashboard scoped to the bundles bucket, then paste the endpoint + keys here.
# In production, set these via `wrangler secret put <NAME>`.
R2_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bearer token for the internal /cron/[job] route. The scheduled handler in
# cron/job.js sends this as `Authorization: Bearer ${CRON_SECRET}` when it
# fires the synthetic request. Without it, scheduled jobs log a refusal and
# skip — set it in production via `wrangler secret put CRON_SECRET`. Generate
# one with `openssl rand -hex 16`.
CRON_SECRET=

# --- Optional tunables ------------------------------------------------------
# Uncomment and adjust as needed. Defaults are applied when unset/empty.
#
# Lifetime of presigned bundle GET URLs (seconds). Devices on slow networks
# may need a higher value. Default 3600 (1h). Min 60, max 7 days (AWS SigV4 cap).
# R2_DOWNLOAD_TTL_SECONDS=3600
#
# Days of stats_events history to retain. Set to 0 (or empty) to disable
# the daily prune cron entirely. Default 90.
# STATS_RETENTION_DAYS=90
