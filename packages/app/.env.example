# Copy to `.env` and fill in. Loaded by Vite at build time and by wrangler
# at deploy/dev start. The Deploy-to-Cloudflare wizard also reads this file
# to prompt for required values when forking the repo.

# Local-dev override for the HYPERDRIVE binding. postgres.js reads this
# connection string when `wrangler dev` runs so the Worker talks directly to
# your Postgres (bypassing Hyperdrive's edge pool during dev). Wrangler loads
# it from `.env` automatically.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE=postgres://capgo_update_lite:<password>@<host>:<port>/capgo_update_lite?sslmode=require

# Admin bearer token. Consumed via `$env/static/private` — baked into the
# bundle at build time, so it must be present in the build environment (not
# as a runtime Worker secret). For CF Workers Builds, also set this as a
# build-time variable in the dashboard's "Variables" settings.
PRIVATE_ADMIN_TOKEN=
