# Copy to `.env` and fill in. Loaded by Vite at build + dev start, and by
# wrangler at startup as process env.
#
# Hyperdrive local-dev override for the HYPERDRIVE binding. postgres.js reads
# the connection string from here when running `wrangler dev`. Secrets in
# `.dev.vars` are for the *Worker's* env; this one is for wrangler itself.
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgres://capgo_update_lite:<password>@<host>:<port>/capgo_update_lite?sslmode=require"

# Consumed via `$env/static/private` — baked into the bundle at build time
# (not a runtime Worker secret). For CF Workers Build, also set this as a
# build-time env var in the Workers Build settings; the runtime `.dev.vars`
# / `wrangler secret` ADMIN_TOKEN is not visible to `vite build`.
PRIVATE_ADMIN_TOKEN="<long random string>"
