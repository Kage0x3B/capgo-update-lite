    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "noEmit": true,
        "declaration": true,
        "lib": ["es2022"]
    },
    "include": ["src/**/*.ts"]
}
