{
    "name": "capgo-update-lite-cli",
    "version": "0.1.0",
    "description": "CLI for publishing Capacitor bundles to a capgo-update-lite OTA server.",
    "type": "module",
    "bin": {
        "capgo-update": "./dist/index.mjs"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.mjs",
        "check": "tsc --noEmit",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "jszip": "^3.10.1"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsdown": "^0.21.10",
        "tsx": "^4.21.0",
        "typescript": "^5.9.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "keywords": [
        "capgo",
        "capacitor",
        "ota",
        "cli",
        "publish"
    ]
}
