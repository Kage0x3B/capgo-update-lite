{
    "name": "capgo-update-lite-cli",
    "version": "0.2.0",
    "description": "CLI for publishing Capacitor bundles to a capgo-update-lite OTA server.",
    "type": "module",
    "bin": {
        "capgo-update-lite": "dist/index.mjs"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsx src/index.ts",
        "start": "node dist/index.mjs",
        "check": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "pnpm build"
    },
    "dependencies": {
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "jszip": "^3.10.1"
    },
    "devDependencies": {
        "@types/node": "^25.6.0",
        "tsdown": "^0.21.10",
        "tsx": "^4.21.0",
        "typescript": "^5.9.0",
        "vitest": "^4.1.5"
    },
    "keywords": [
        "capgo",
        "capacitor",
        "ota",
        "cli",
        "publish",
        "cloudflare-workers"
    ],
    "author": {
        "name": "Moritz Hein",
        "email": "moritz.hein@live.de",
        "url": "https://moritz.website"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Kage0x3B/capgo-update-lite.git",
        "directory": "packages/cli"
    },
    "homepage": "https://github.com/Kage0x3B/capgo-update-lite/tree/main/packages/cli#readme",
    "bugs": {
        "url": "https://github.com/Kage0x3B/capgo-update-lite/issues"
    }
}
