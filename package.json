{
  "name": "capgo-update-lite",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && tsc -p scripts/tsconfig.json",
    "deploy": "vite build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "publish-bundle": "tsx scripts/publish.ts",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "jszip": "^3.10.1",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.9",
    "wrangler": "^4.84.1"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "drizzle-orm": "^0.45.2",
    "nanoid": "^5.1.9",
    "postgres": "^3.4.9",
    "valibot": "^1.3.1"
  }
}
